---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  [key: string]: any;
}

const { src, alt, class: className, width, height, ...props } = Astro.props;

let isRemote = typeof src === 'string' && (src.startsWith('http://') || src.startsWith('https://') || src.startsWith('blob:'));

// Mapeia dinamicamente todas as imagens da pasta public para permitir otimização do Astro
const images = import.meta.glob<{ default: ImageMetadata }>('/public/**/*.{jpeg,jpg,png,gif,webp,avif}');
let finalSrc: string | ImageMetadata = src;
let finalInferSize: boolean | undefined = undefined;

if (typeof src === 'string' && !isRemote && src.startsWith('/')) {
    // Tenta encontrar a imagem local na pasta public
    const path = `/public${src}`;
    if (images[path]) {
        // Carrega o módulo da imagem localmente (Isso faz com que o Astro a processe e otimize!)
        finalSrc = (await images[path]()).default;
    }
} else if (isRemote) {
    // Se for URL externa (ex: unsplash), pedimos pro Astro inferir o tamanho original
    if (!width || !height) {
        finalInferSize = true;
    }
}
---
{finalSrc && <Image src={finalSrc as any} alt={alt || ""} class={className} width={width} height={height} inferSize={finalInferSize} format="webp" {...props} />}
