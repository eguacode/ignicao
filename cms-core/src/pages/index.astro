---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { readData } from "../lib/readData";
import { postUrl, blogIndexUrl } from "../lib/blogRoutes";
import OptimizedImage from "../components/ui/OptimizedImage.astro";

const allPosts = await getCollection("blog");
const publishedPosts = allPosts
  .filter((post: any) => !post.data.draft)
  .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroConfig = readData('hero.json', {
  badge: "Construa sua Liberdade Financeira com Suporte Profissional",
  titlePrefix: "Acelere o seu Sucesso com uma ",
  titleHighlight: "Mentoria Exclusiva de Negócios",
  description: "Tenha direcionamento passo a passo com quem já conhece o caminho para o topo. Aprenda a escalar o seu negócio de marketing de rede, desenvolver liderança de equipe e criar uma nova fonte de renda sólida e duplicável.",
  btn1Text: "Quero Ser Mentorado",
  btn1Link: "https://wa.me/5591981992265",
  btn2Text: "Conhecer o Modelo de Negócio",
  btn2Link: "#how-it-works",
  image: "/images/hero.png"
});

const siteConfig = readData('siteConfig.json', {});
const bannersConfig = readData('banners.json', []);

const homeConfig = readData('home.json', {
    sectionTitles: {
        editorsPick: 'Escolha dos Editores',
        trending: 'Em Alta',
        inspiration: 'Inspiração',
        latestPosts: 'Posts Recentes',
    },
    editorsPick: { mainSlug: '', sideSlugs: [] },
    trending: { slugs: [] },
    inspiration: { slugs: [] },
});

const getPostBySlug = (slug: string) => allPosts.find((p: any) => p.slug === slug);

const editorsMainPost = getPostBySlug(homeConfig.editorsPick?.mainSlug) || publishedPosts[0];
const editorsSidePosts = (homeConfig.editorsPick?.sideSlugs || []).map(getPostBySlug).filter(Boolean);
if (editorsSidePosts.length === 0) editorsSidePosts.push(...publishedPosts.slice(1, 5));

const trendingPosts = (homeConfig.trending?.slugs || []).map(getPostBySlug).filter(Boolean);
if (trendingPosts.length === 0) trendingPosts.push(...publishedPosts.slice(0, 4));

const inspirationPosts = (homeConfig.inspiration?.slugs || []).map(getPostBySlug).filter(Boolean);
if (inspirationPosts.length === 0) inspirationPosts.push(...publishedPosts.slice(0, 4));
---

<BaseLayout
  title="Comunidade Ignição | Ative sua melhor versão!"
  description="Ative sua melhor versão! Construa sua rede de marketing e conecte-se com mentores experientes para alavancar sua carreira e negócios."
>
  <!-- Hero Section -->
  <section class="relative bg-slate-50 pt-20 pb-28 overflow-hidden">
    <!-- Decoração de fundo -->
    <div
      class="absolute inset-y-0 right-0 w-1/2 bg-orange-50 rounded-l-[100px] opacity-60 -z-10"
    >
    </div>
    <div
      class="absolute top-20 right-20 w-72 h-72 bg-red-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="max-w-2xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-sm font-semibold mb-6"
          >
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"
            ></span>
            {heroConfig.badge}
          </div>
          <h1
            class="text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-6"
          >
            {heroConfig.titlePrefix} <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-600"
              >{heroConfig.titleHighlight}</span
            >
          </h1>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed whitespace-pre-line">
            {heroConfig.description}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={heroConfig.btn1Link}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 px-8 rounded-full transition-all shadow-lg hover:shadow-orange-500/30 transform hover:-translate-y-1"
            >
              {heroConfig.btn1Text}
            </a>
            <a
              href={heroConfig.btn2Link}
              class="flex items-center justify-center bg-white border-2 border-slate-200 hover:border-orange-500 hover:text-orange-600 text-slate-700 font-bold py-4 px-8 rounded-full transition-all"
            >
              {heroConfig.btn2Text}
            </a>
          </div>
        </div>

        <!-- Image Content -->
        <div class="relative hidden lg:block">
          <div
            class="relative rounded-3xl overflow-hidden shadow-2xl transform rotate-2 hover:rotate-0 transition-transform duration-500"
          >
            <!-- Hero Image generatd by AI -->
            <OptimizedImage
              src={heroConfig.image}
              alt={heroConfig.titleHighlight}
              class="w-full h-auto object-cover"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"
            >
            </div>
          </div>
          <!-- Card Flutuante -->
          <div
            class="absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl flex items-center gap-4 animate-bounce"
            style="animation-duration: 3s;"
          >
            <div class="flex -space-x-4">
              <img
                class="w-12 h-12 rounded-full border-2 border-white object-cover bg-slate-200"
                src="https://i.pravatar.cc/100?img=1"
                alt="Avatar 1"
              />
              <img
                class="w-12 h-12 rounded-full border-2 border-white object-cover bg-slate-200"
                src="https://i.pravatar.cc/100?img=2"
                alt="Avatar 2"
              />
              <img
                class="w-12 h-12 rounded-full border-2 border-white object-cover bg-slate-200"
                src="https://i.pravatar.cc/100?img=3"
                alt="Avatar 3"
              />
              <div
                class="w-12 h-12 rounded-full border-2 border-white bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-600"
              >
                +1.5k
              </div>
            </div>
            <div class="text-sm font-bold text-slate-800 leading-tight">
              Mais de 1.500+<br /><span class="text-orange-600"
                >Empreendedores Conectados ao Nosso Sistema</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Box Escuro Premium com a Logo das Redes Sociais -->
        <div class="order-2 lg:order-1 relative w-full max-w-[480px] mx-auto">
          <div
            class="bg-slate-950 rounded-3xl p-8 sm:p-12 flex items-center justify-center shadow-xl border border-slate-800/50 aspect-square w-full"
          >
            <OptimizedImage
              src={siteConfig.logo || "/images/about.png"}
              alt="Logo Comunidade Ignição"
              class="w-full h-auto max-w-[340px] object-contain"
            />
          </div>
        </div>

        <div class="order-1 lg:order-2 flex flex-col justify-center">
          <div
            class="mb-2 text-orange-600 font-bold tracking-wider uppercase text-sm"
          >
            Quem Somos
          </div>
          <h2 class="text-4xl font-extrabold text-slate-900 mb-6">
            Apoio Direto e Estrutura para Você Alcançar os Seus Objetivos
          </h2>
          <p class="text-slate-600 text-lg mb-8">
            Somos uma comunidade de líderes e empreendedores focados em
            transformar vidas através do marketing de rede profissional. Nós
            quebramos o amadorismo do mercado fornecendo as ferramentas
            digitais, o ecossistema de treinamento e o acompanhamento diário que
            você precisa para sair do zero e construir uma organização de
            sucesso.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <!-- Missão -->
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
              <div
                class="w-12 h-12 bg-orange-100 text-orange-600 rounded-xl flex items-center justify-center mb-4"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">
                Nossa Missão
              </h3>
              <p class="text-slate-600 text-sm">
                Capacitar pessoas comuns a desenvolverem uma mentalidade
                empreendedora forte, conquistando autonomia financeira através
                de um método simples e 100% duplicável.
              </p>
            </div>
            <!-- Visão -->
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
              <div
                class="w-12 h-12 bg-red-100 text-red-600 rounded-xl flex items-center justify-center mb-4"
              >
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">Nossa Visão</h3>
              <p class="text-slate-600 text-sm">
                Ser o maior e mais efetivo sistema de formação de líderes em
                marketing de rede do país, reconhecida pelo suporte prático e
                resultados reais na vida dos nossos parceiros.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <section class="py-16 bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center divide-x divide-slate-800"
      >
        <div class="px-4">
          <div class="text-4xl md:text-5xl font-extrabold text-orange-400 mb-2">
            +500
          </div>
          <p class="text-slate-400 font-medium">
            Horas de Treinamento e Mentoria ao Vivo
          </p>
        </div>
        <div class="px-4">
          <div class="text-4xl md:text-5xl font-extrabold text-orange-400 mb-2">
            +5 Mil
          </div>
          <p class="text-slate-400 font-medium">
            Vidas Transformadas através do Nosso Modelo
          </p>
        </div>
        <div class="px-4">
          <div class="text-4xl md:text-5xl font-extrabold text-orange-400 mb-2">
            26
          </div>
          <p class="text-slate-400 font-medium">
            Estados com Líderes em Expansão
          </p>
        </div>
        <div class="px-4">
          <div class="text-4xl md:text-5xl font-extrabold text-orange-400 mb-2">
            100%
          </div>
          <p class="text-slate-400 font-medium">
            De Suporte na Sua Jornada de Duplicação
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div
          class="mb-2 text-orange-600 font-bold tracking-wider uppercase text-sm"
        >
          Jornada do Membro
        </div>
        <h2 class="text-4xl font-extrabold text-slate-900 mb-4">
          Sua Jornada para o Sucesso
        </h2>
        <p class="text-slate-600 text-lg">
          Três passos simples separam você de integrar a melhor rede de
          profissionais do mercado. <span class="text-orange-600"
            >Entra um membro e sai um líder</span
          >
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Passo 1 -->
        <div
          class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-xl transition-shadow relative overflow-hidden group"
        >
          <div
            class="absolute top-0 right-0 w-24 h-24 bg-orange-50 rounded-bl-full -z-10 group-hover:scale-150 transition-transform"
          >
          </div>
          <div
            class="w-16 h-16 bg-orange-50 text-orange-600 rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto mb-6"
          >
            01
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">Conheça o Plano</h3>
          <p class="text-slate-600">
            Assista à nossa apresentação exclusiva de negócios. Entenda o
            mercado, o produto e a projeção de ganhos financeiros para o seu
            perfil.
          </p>
        </div>
        <!-- Passo 2 -->
        <div
          class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-xl transition-shadow relative overflow-hidden group"
        >
          <div
            class="absolute top-0 right-0 w-24 h-24 bg-red-50 rounded-bl-full -z-10 group-hover:scale-150 transition-transform"
          >
          </div>
          <div
            class="w-16 h-16 bg-orange-100 text-orange-700 rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto mb-6"
          >
            02
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">
            Ativação e Alinhamento
          </h3>
          <p class="text-slate-600">
            Abra sua ferramenta de trabalho, defina suas primeiras metas com o
            seu mentor e tenha acesso imediato ao nosso plano prático de ação de
            90 dias.
          </p>
        </div>
        <!-- Passo 3 -->
        <div
          class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center hover:shadow-xl transition-shadow relative overflow-hidden group"
        >
          <div
            class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-bl-full -z-10 group-hover:scale-150 transition-transform"
          >
          </div>
          <div
            class="w-16 h-16 bg-red-50 text-red-600 rounded-2xl flex items-center justify-center text-2xl font-bold mx-auto mb-6"
          >
            03
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">
            Construa sua Nova Renda
          </h3>
          <p class="text-slate-600">
            Utilize o nosso sistema de recrutamento duplicável para expandir sua
            rede de contatos, liderar novas equipes e colher os bônus e
            premiações.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Escolha dos Editores -->
  <section id="editors-pick" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div class="max-w-2xl">
          <div class="mb-2 text-orange-600 font-bold tracking-wider uppercase text-sm">Conteúdos Estratégicos</div>
          <h2 class="text-4xl font-extrabold text-slate-900">{homeConfig.sectionTitles?.editorsPick || 'Escolha dos Editores'}</h2>
        </div>
        <a href={blogIndexUrl()} class="text-orange-600 font-bold hover:text-orange-700 flex items-center gap-1 group">
          Ver todos os artigos <span class="transform group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Main Post -->
        {editorsMainPost && (
          <a href={postUrl(editorsMainPost.slug)} class="group block lg:col-span-8">
            <div class="relative rounded-3xl overflow-hidden h-full min-h-[400px]">
              <OptimizedImage src={editorsMainPost.data.heroImage || '/images/hero.png'} alt={editorsMainPost.data.title || "Artigo principal"} class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent"></div>
              <div class="absolute bottom-0 p-8">
                <span class="inline-block px-3 py-1 bg-orange-500 text-white text-xs font-bold rounded-full mb-4">{editorsMainPost.data.category || 'Geral'}</span>
                <h3 class="text-3xl font-bold text-white mb-2 group-hover:text-orange-400 transition-colors">{editorsMainPost.data.title}</h3>
                <p class="text-slate-300 line-clamp-2">{editorsMainPost.data.description}</p>
              </div>
            </div>
          </a>
        )}
        
        <!-- Side Posts -->
        <div class="lg:col-span-4 flex flex-col gap-6">
          {editorsSidePosts.slice(0,4).map((post: any) => (
            <a href={postUrl(post.slug)} class="group flex gap-4 items-center">
              <div class="w-24 h-24 shrink-0 rounded-2xl overflow-hidden">
                <OptimizedImage src={post.data.heroImage || '/images/hero.png'} alt={post.data.title || "Artigo destaque"} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500" />
              </div>
              <div>
                <span class="text-xs font-bold text-orange-500 uppercase tracking-wider">{post.data.category || 'Geral'}</span>
                <h4 class="font-bold text-slate-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-tight mt-1">{post.data.title}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {bannersConfig && bannersConfig.length > 0 && (
    <section class="py-16 bg-slate-900 border-t border-slate-800 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 text-center">
        <h2 class="text-3xl font-extrabold text-white mb-4">Qualificações da Equipe</h2>
        <p class="text-slate-400">Celebramos as conquistas e o avanço dos nossos membros.</p>
      </div>
      
      <div class="w-full relative px-4 sm:px-6 lg:px-8 max-w-[100vw]">
        <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 pt-4 hide-scrollbar">
          {bannersConfig.map((banner: any) => (
            <div class="snap-center shrink-0 w-64 md:w-72 relative group transform transition-all hover:-translate-y-2">
              <div class="rounded-2xl overflow-hidden shadow-2xl border-4 border-slate-800 group-hover:border-orange-500 transition-colors aspect-[9/16] bg-slate-800 relative">
                {banner.image ? (
                  <OptimizedImage src={banner.image} alt={banner.name} class="absolute inset-0 w-full h-full object-cover" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-slate-600">Sem imagem</div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent opacity-80"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                  <h3 class="text-xl font-bold text-white mb-1 drop-shadow-md">{banner.name}</h3>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      </style>
    </section>
  )}
  <!-- Em Alta -->
  <section id="trending" class="py-16 bg-slate-50 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-slate-900 mb-10">{homeConfig.sectionTitles?.trending || 'Em Alta'}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {trendingPosts.slice(0,4).map((post: any) => (
          <a href={postUrl(post.slug)} class="group bg-white p-4 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow flex gap-4 items-center">
            <div class="w-24 md:w-32 h-24 md:h-32 shrink-0 rounded-xl overflow-hidden">
              <OptimizedImage src={post.data.heroImage || '/images/hero.png'} alt={post.data.title || "Artigo em alta"} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex-1">
              <span class="text-xs font-bold text-orange-500 mb-1 block">{post.data.category || 'Geral'}</span>
              <h4 class="text-lg font-bold text-slate-800 group-hover:text-orange-600 transition-colors line-clamp-2">{post.data.title}</h4>
              <span class="text-xs text-slate-400 mt-2 block">{post.data.pubDate.toLocaleDateString('pt-BR')}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Inspiração -->
  <section id="inspiration" class="py-16 bg-white border-t border-slate-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 text-center">
      <h2 class="text-3xl font-extrabold text-slate-900">{homeConfig.sectionTitles?.inspiration || 'Inspiração'}</h2>
    </div>
    
    <div class="w-full relative px-4 sm:px-6 lg:px-8 max-w-[100vw] mx-auto xl:max-w-7xl">
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 pt-4 hide-scrollbar">
        {inspirationPosts.map((post: any) => (
          <a href={postUrl(post.slug)} class="snap-center shrink-0 w-72 relative group block">
            <div class="h-96 rounded-2xl overflow-hidden shadow-md relative border border-slate-200">
              <OptimizedImage src={post.data.heroImage || '/images/hero.png'} alt={post.data.title || "Artigo de inspiração"} class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <span class="inline-block px-2 py-1 bg-white/20 backdrop-blur-md text-white text-xs font-bold rounded-lg mb-3">{post.data.category || 'Geral'}</span>
                <h3 class="text-xl font-bold text-white leading-snug">{post.data.title}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
