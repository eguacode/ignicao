---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import EmailInlineBanner from '../../plugins/email-list/EmailInlineBanner.astro';
import AffiliateProducts from '../../plugins/affiliates/AffiliateProducts.astro';
import PostSchemaPlugins from '../../plugins/_slots/PostSchemaPlugins.astro';
import PostBottomPlugins from '../../plugins/_slots/PostBottomPlugins.astro';
import PostAfterPlugins from '../../plugins/_slots/PostAfterPlugins.astro';
import SocialShare from '../../plugins/social-share/SocialShare.astro';
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
import { postUrl } from '../../lib/blogRoutes';
const authorsData = readData('authors.json', []);

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const inlineConfig = pluginsConfig?.emailList?.inline;
const inlineEnabled = inlineConfig?.enabled === true;
const inlinePosition = Number(inlineConfig?.position ?? 3);

export async function getStaticPaths() {
  const siteConfig = (await import('../../lib/readData')).readData('siteConfig.json');
  const prefix = siteConfig.blogPrefix ?? '';

  // Só gera rotas em /blog/ se o prefix for "/blog"
  if (prefix !== '/blog') return [];

  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
const post = Astro.props;
const { Content } = await post.render();

const currentAuthor = authorsData.find((a: any) => a.id === post.data.author) || authorsData[0] || {
  name: 'Equipe',
  role: 'Redação',
  avatar: '',
  bio: ''
};

const categorySlug = post.data.category ? post.data.category.toLowerCase().replace(/[^a-z0-9]/g, '-') : '';
const siteConfig = readData('siteConfig.json', {}) as any;
const fullPostUrl = `${siteConfig.url || Astro.url.origin}${postUrl(post.slug)}`;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article" author={currentAuthor?.name} pubDate={post.data.pubDate}>
  <PostSchemaPlugins
    title={post.data.title}
    description={post.data.description || ''}
    url={fullPostUrl}
    image={post.data.heroImage}
    datePublished={post.data.pubDate instanceof Date ? post.data.pubDate.toISOString() : post.data.pubDate}
    authorName={currentAuthor?.name}
    category={post.data.category}
  />

  <!-- Reading Progress Bar -->
  <div id="progress-bar" class="fixed top-[76px] left-0 h-1 bg-orange-500 z-50 transition-all duration-150 ease-out w-0"></div>

  <section class="max-w-7xl mx-auto px-4 py-12 md:py-20">
    <!-- Breadcrumb -->
    <nav class="text-sm font-medium text-slate-400 mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-orange-500 transition-colors">Home</a>
      {post.data.category && (
        <>
          <span>/</span>
          <a href={`/categoria/${categorySlug}`} class="hover:text-orange-500 transition-colors">{post.data.category}</a>
        </>
      )}
      <span>/</span>
      <span class="text-slate-300 truncate max-w-[200px] md:max-w-xs">{post.data.title}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Main article -->
      <article class="flex-1 min-w-0">
        <!-- Post header -->
        <header class="mb-10">
          {post.data.category && (
            <a href={`/categoria/${categorySlug}`} class="inline-block px-4 py-1.5 bg-orange-100 text-orange-700 text-xs font-bold uppercase tracking-widest rounded-full mb-6 hover:bg-orange-200 transition-colors">{post.data.category}</a>
          )}
          <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 leading-tight mb-8">
            {post.data.title}
          </h1>
          <div class="flex flex-wrap items-center justify-between gap-6 pb-4 border-b border-slate-100">
            <div class="flex items-center gap-3 text-sm font-medium text-slate-500">
              {currentAuthor.avatar ? (
                <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-10 h-10 rounded-full object-cover shadow-sm" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 font-bold text-sm">
                  {currentAuthor.name.charAt(0)}
                </div>
              )}
              <div class="flex flex-col">
                <span class="text-slate-800 font-bold">{currentAuthor.name}</span>
                <time class="text-xs text-slate-400">{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
              </div>
            </div>
            <div>
              <SocialShare title={post.data.title} context="post-bottom" />
            </div>
          </div>
        </header>

        <!-- Featured image -->
        {post.data.heroImage && (
          <div class="mb-12 w-full relative rounded-3xl overflow-hidden shadow-md aspect-video md:aspect-[16/9]">
            <img src={post.data.heroImage} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover" />
          </div>
        )}

        <!-- Main Content wrapper with Prose -->
        <div class="prose prose-slate prose-orange lg:prose-lg max-w-none prose-img:rounded-2xl prose-img:shadow-md prose-headings:font-bold prose-a:text-orange-600 prose-a:no-underline hover:prose-a:underline post-content">
          <Content />
        </div>

        <!-- Email inline banner -->
        {inlineEnabled && (
          <div id="email-inline-source" data-position={inlinePosition} style="display:none">
            <div class="my-10">
              <EmailInlineBanner />
            </div>
          </div>
        )}

        <!-- Affiliate products -->
        <div class="my-12">
          <AffiliateProducts />
        </div>

        <!-- Post bottom: tags + social share -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mt-16 pt-8 border-t border-slate-200">
          <div>
            {post.data.category && (
              <a href={`/categoria/${categorySlug}`} class="inline-block px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg hover:bg-slate-200 transition-colors">#{post.data.category}</a>
            )}
          </div>
          <PostBottomPlugins title={post.data.title} />
        </div>

        <!-- About author -->
        <div class="bg-slate-50 rounded-3xl border border-slate-100 p-8 mt-12 flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-6 shadow-sm">
          {currentAuthor.avatar ? (
            <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-24 h-24 rounded-full object-cover shadow-md flex-shrink-0 border-4 border-white" />
          ) : (
            <div class="w-24 h-24 rounded-full bg-white flex items-center justify-center text-3xl font-bold text-orange-400 flex-shrink-0 shadow-sm border border-slate-100">
              {currentAuthor.name.charAt(0)}
            </div>
          )}
          <div class="flex-1">
            <h4 class="text-xl font-bold text-slate-900 mb-1">{currentAuthor.name}</h4>
            {currentAuthor.role && <p class="text-sm font-bold text-orange-500 uppercase tracking-wider mb-3">{currentAuthor.role}</p>}
            {currentAuthor.bio && <p class="text-slate-600 leading-relaxed mb-4">{currentAuthor.bio}</p>}
            <div class="flex justify-center sm:justify-start">
              <SocialShare title={post.data.title} context="author-box" />
            </div>
          </div>
        </div>

        <!-- Post after: related posts, comments, etc. -->
        <div class="mt-16">
          <PostAfterPlugins
            currentSlug={post.slug}
            category={post.data.category || ''}
          />
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-80 flex-shrink-0">
        <Sidebar />
      </aside>
    </div>
  </section>

  <script is:inline>
  // Replace &nbsp; from Quill editor with normal spaces
  (function() {
    var postContent = document.querySelector('.post-content');
    if (!postContent) return;
    var walker = document.createTreeWalker(postContent, NodeFilter.SHOW_TEXT, null);
    var node;
    while ((node = walker.nextNode())) {
      if (node.nodeValue && node.nodeValue.indexOf('\u00A0') !== -1) {
        node.nodeValue = node.nodeValue.replace(/\u00A0/g, ' ');
      }
    }
  })();
  </script>

  {inlineEnabled && (
    <script>
    (function() {
      const source = document.getElementById('email-inline-source');
      if (!source) return;
      const pos = Number((source as HTMLElement).dataset.position) || 3;
      const paragraphs = document.querySelectorAll('.post-content > p');
      const target = paragraphs[pos - 1] || paragraphs[paragraphs.length - 1];
      if (target) {
        target.insertAdjacentElement('afterend', source);
        source.style.display = 'block';
      }
    })();
    </script>
  )}

  <script is:inline>
    // Reading progress bar logic
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const bar = document.getElementById('progress-bar');
      if(bar) bar.style.width = scrolled + '%';
    });
  </script>

</BaseLayout>
