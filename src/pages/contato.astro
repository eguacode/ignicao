---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contato | Ignição" 
  description="Entre em contato com nossa equipe para dúvidas sobre mentoria, negócios e parcerias."
>
  <!-- Hero Section Contato -->
  <section class="relative bg-slate-50 pt-20 pb-16 overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 bg-emerald-50 rounded-bl-[100px] opacity-60 -z-10 h-full"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto">
        <div class="mb-2 text-emerald-600 font-bold tracking-wider uppercase text-sm">Fale Conosco</div>
        <h1 class="text-5xl font-extrabold text-slate-900 mb-6">Como podemos ajudar você hoje?</h1>
        <p class="text-lg text-slate-600">
          Nossa equipe de suporte está pronta para tirar suas dúvidas sobre o modelo de negócios, mentorias ou parcerias.
        </p>
      </div>
    </div>
  </section>

  <!-- Form & Infos -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-slate-900 mb-8">Informações de Contato</h2>
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-1">E-mail</h3>
                <p class="text-slate-600">Mande um e-mail a qualquer hora e responderemos em até 24h.</p>
                <a href="mailto:hugomurilosc@gmail.com" class="text-emerald-600 font-bold hover:underline mt-2 inline-block">hugomurilosc@gmail.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-teal-100 text-teal-600 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-1">WhatsApp</h3>
                <p class="text-slate-600">Para um atendimento mais rápido e direto, fale com nosso suporte via WhatsApp.</p>
                <a href="https://wa.me/5591981992265" target="_blank" class="text-emerald-600 font-bold hover:underline mt-2 inline-block">+55 (91) 98199-2265</a>
              </div>
            </div>


          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-xl relative">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-emerald-500 rounded-full mix-blend-multiply filter blur-2xl opacity-20"></div>
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-teal-500 rounded-full mix-blend-multiply filter blur-2xl opacity-20"></div>
          
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Envie uma Mensagem</h3>
          <form action="https://formsubmit.co/hugomurilosc@gmail.com" method="POST" class="space-y-6">
            <!-- Configurações do FormSubmit -->
            <input type="hidden" name="_subject" value="Novo Contato via Site Ignição!">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Seu Nome</label>
                <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all" placeholder="João Silva" required>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">WhatsApp</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all" placeholder="(11) 99999-9999" required>
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-2">E-mail</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all" placeholder="joao@exemplo.com" required>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Como podemos ajudar?</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all resize-none" placeholder="Gostaria de saber mais sobre a mentoria..." required></textarea>
            </div>
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 rounded-xl transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
              Enviar Mensagem Agora
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
