---
import BaseSEO from "../components/BaseSEO.astro";
import "../styles/global.css";
import { Image } from "astro:assets";
import logoImg from "../assets/logo-ignicao.png";
import siteConfig from "../../cms-core/src/data/siteConfig.json";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string | URL;
}

const { title, description, image, canonicalURL } = Astro.props;
---

<html lang="pt-br">
  <head>
    <BaseSEO
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
    />
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col font-sans">
    <!-- Header -->
    <header
      class="bg-white/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 shadow-sm"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center"
      >
        <!-- Logo Otimizada no Header -->
        <a href="/" class="flex items-center">
          <Image
            src={logoImg}
            alt="Logo Comunidade Ignição - Mentoria e Marketing de Rede"
            width={180}
            loading="eager"
          />
        </a>

        <!-- Desktop Menu -->
        <nav
          class="hidden md:flex items-center gap-8 font-medium text-slate-600"
        >
          <a href="/" class="hover:text-orange-600 transition-colors">Início</a>
          <a href="/#about" class="hover:text-orange-600 transition-colors"
            >Sobre Nós</a
          >
          <a
            href="/#how-it-works"
            class="hover:text-orange-600 transition-colors">Como Funciona</a
          >

          <!-- Dropdown Conteúdos -->
          <div class="relative group h-full flex items-center">
            <a
              href="#blog"
              class="hover:text-orange-600 transition-colors flex items-center gap-1 cursor-pointer py-4"
            >
              Conteúdos
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 transition-transform group-hover:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </a>
            <!-- Submenu (Categorias) -->
            <div
              class="absolute top-full left-0 w-60 bg-white border border-slate-100 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
            >
              <div class="py-2">
                <a
                  href="/blog/categoria/recrutamento"
                  class="block px-5 py-3 text-sm text-slate-600 hover:bg-orange-50 hover:text-orange-700 transition-colors border-b border-slate-50"
                  >Recrutamento</a
                >
                <a
                  href="/blog/categoria/lideranca"
                  class="block px-5 py-3 text-sm text-slate-600 hover:bg-orange-50 hover:text-orange-700 transition-colors border-b border-slate-50"
                  >Liderança</a
                >
                <a
                  href="/blog/categoria/vendas"
                  class="block px-5 py-3 text-sm text-slate-600 hover:bg-orange-50 hover:text-orange-700 transition-colors border-b border-slate-50"
                  >Vendas</a
                >
                <a
                  href="/blog/categoria/mentalidade"
                  class="block px-5 py-3 text-sm text-slate-600 hover:bg-orange-50 hover:text-orange-700 transition-colors"
                  >Mentalidade</a
                >
                <div class="border-t border-slate-100 my-1"></div>
                <a
                  href="/blog"
                  class="block px-5 py-3 text-xs font-bold text-orange-600 hover:text-orange-700 uppercase tracking-wider text-center transition-colors"
                  >Ver Todos os Artigos</a
                >
              </div>
            </div>
          </div>

          <a href="/contato" class="hover:text-orange-600 transition-colors"
            >Contato</a
          >
        </nav>

        <!-- Actions -->
        <div class="hidden md:flex items-center gap-4">
          <!-- Botão Principal com Degradê de Fogo (Laranja para Vermelho) -->
          <a
            href="https://wa.me/5591981992265?text=Ol%C3%A1%20Hugo%2C%20quero%20come%C3%A7ar%20agora%20na%20Mentoria%20de%20Neg%C3%B3cios"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-gradient-to-r from-orange-500 to-red-600 hover:from-orange-600 hover:to-red-700 text-white font-semibold px-6 py-2.5 rounded-full transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5"
            >Começar Agora <span class="ml-1">&rarr;</span></a
          >
        </div>

        <!-- Mobile Menu Button -->
        <button class="md:hidden text-slate-600 hover:text-orange-600 p-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          </svg>
        </button>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer
      class="bg-slate-900 text-slate-300 py-12 mt-20 border-t border-slate-800"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-8"
      >
        <div class="col-span-1 md:col-span-2">
          <!-- Logo Otimizada no Footer -->
          <a href="/" class="flex items-center mb-4">
            <Image
              src={logoImg}
              alt="Logo Comunidade Ignição - Mentoria e Marketing de Rede"
              width={140}
              class="brightness-0 invert opacity-90"
            />
          </a>
          <p class="text-slate-400 max-w-md" set:html={siteConfig.footer.description}></p>
        </div>
        <div>
          <h4
            class="text-white font-semibold mb-4 uppercase tracking-wider text-sm"
          >
            Links Úteis
          </h4>
          <ul class="space-y-2">
            <li>
              <a href="/#about" class="hover:text-orange-400 transition-colors"
                >Sobre Nós</a>
            </li>
            <li>
              <a
                href="/#how-it-works"
                class="hover:text-orange-400 transition-colors"
                >Jornada do Membro</a>
            </li>
            <li>
              <a href="/blog" class="hover:text-orange-400 transition-colors"
                >Blog & Guias</a>
            </li>
            <li>
              <a href="/contato" class="hover:text-orange-400 transition-colors"
                >Entre em Contato</a>
            </li>
          </ul>
        </div>
        <div>
          <h4
            class="text-white font-semibold mb-4 uppercase tracking-wider text-sm"
          >
            Contato
          </h4>
          <ul class="space-y-2">
            <li class="flex items-center gap-2">
              <span class="text-orange-400">&bull;</span> hugomurilosc@gmail.com
            </li>
            <li class="flex items-center gap-2">
              <span class="text-emerald-400">&bull;</span> +55 (91) 98199-2265
            </li>
          </ul>
        </div>
      </div>
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-slate-800 text-center text-sm text-slate-500"
      >
        <p>
          &copy; {new Date().getFullYear()} {siteConfig.footer.copyright || "Ignição"}. Todos os direitos reservados.
        </p>
      </div>
    </footer>
  </body>
</html>
