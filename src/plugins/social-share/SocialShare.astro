---
/**
 * SocialShare.astro — Plugin Social Share
 *
 * Renderiza título + botões de compartilhamento com URLs funcionais.
 * Lê configurações de pluginsConfig.socialShare.
 */
import { readData } from '../../lib/readData';

interface Props {
  title?: string;
  context?: 'post-bottom' | 'author-box';
}

const { title = '', context = 'post-bottom' } = Astro.props;

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const shareConfig = pluginsConfig?.socialShare;
const enabled = shareConfig?.enabled !== false;
const style = shareConfig?.style || 'icon';
const sectionTitle: string = shareConfig?.sectionTitle || 'Compartilhe nas redes sociais';
const platforms: string[] = shareConfig?.platforms || [
  'facebook', 'twitter', 'whatsapp', 'linkedin', 'telegram', 'copy'
];

const platformDefs: Record<string, { svg: string; label: string; viewBox: string }> = {
  facebook:  { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>', label: 'Facebook' },
  twitter:   { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>', label: 'Twitter/X' },
  whatsapp:  { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path>', label: 'WhatsApp' },
  linkedin:  { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>', label: 'LinkedIn' },
  telegram:  { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.888-.662 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"></path>', label: 'Telegram' },
  pinterest: { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.168 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.624 0 12.017 0z"></path>', label: 'Pinterest' },
  copy:      { viewBox: "0 0 24 24", svg: '<path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path>', label: 'Copiar' },
};

const activePlatforms = platforms.filter(p => platformDefs[p]);
---

{enabled && activePlatforms.length > 0 && (
  <div class="walker-share-wrap" data-context={context}>
    {sectionTitle && (
      <p class="walker-share-title">{sectionTitle}</p>
    )}
    <ul
      class="social-icons flex flex-wrap gap-2 m-0 p-0 list-none walker-share-list"
      data-style={style}
    >
      {activePlatforms.map(p => {
        const def = platformDefs[p];
        return (
          <li class="flex items-center" data-platform={p}>
            <a href="#" class="walker-share-btn w-9 h-9 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-orange-100 hover:text-orange-600 transition-colors shadow-sm" aria-label={`Compartilhar no ${def.label}`} title={def.label}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox={def.viewBox} class="svg-icon" set:html={def.svg}></svg>
              {(style === 'label' || style === 'both') && (
                <span class="share-label ms-1 text-sm font-medium">{def.label}</span>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
)}

<style>
  .walker-share-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }

  .walker-share-wrap[data-context="post-bottom"] {
    align-items: flex-end;
  }

  .walker-share-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9bac;
    margin: 0;
    line-height: 1;
  }
</style>

<script>
(function() {
  function initShareButtons() {
    var lists = document.querySelectorAll('.walker-share-list');
    lists.forEach(function(list) {
      var pageUrl = encodeURIComponent(window.location.href);
      var pageTitle = encodeURIComponent(document.title);
      var btns = list.querySelectorAll('.walker-share-btn');
      btns.forEach(function(btn) {
        var li = btn.closest('[data-platform]') as HTMLElement;
        var platform = li?.dataset.platform;
        if (!platform) return;

        var urls: Record<string, string> = {
          facebook:  'https://www.facebook.com/sharer/sharer.php?u=' + pageUrl,
          twitter:   'https://twitter.com/intent/tweet?url=' + pageUrl + '&text=' + pageTitle,
          whatsapp:  'https://wa.me/?text=' + pageTitle + '%20' + pageUrl,
          linkedin:  'https://www.linkedin.com/sharing/share-offsite/?url=' + pageUrl,
          telegram:  'https://t.me/share/url?url=' + pageUrl + '&text=' + pageTitle,
          pinterest: 'https://pinterest.com/pin/create/button/?url=' + pageUrl,
          copy:      'copy',
        };

        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var url = urls[platform!];
          if (url === 'copy') {
            navigator.clipboard?.writeText(window.location.href).then(function() {
              var label = (btn as HTMLElement).querySelector('.share-label');
              var icon = (btn as HTMLElement).querySelector('.svg-icon');
              var original = label ? label.textContent : null;
              var originalSvg = icon ? icon.innerHTML : null;
              if (label) label.textContent = 'Copiado!';
              if (icon && !label) {
                icon.innerHTML = '<path fill="currentColor" d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>';
                setTimeout(function() { if (icon && originalSvg) icon.innerHTML = originalSvg; }, 2000);
              }
              setTimeout(function() { if (label) label.textContent = original; }, 2000);
            });
          } else {
            window.open(url, '_blank', 'noopener,width=600,height=450');
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareButtons);
  } else {
    initShareButtons();
  }
})();
</script>
